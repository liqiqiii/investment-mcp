# FRED API key — register free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# GitHub Pages repo (owner/repo format) for report deployment
GITHUB_PAGES_REPO=

# Data cache directory (defaults to ~/.investment-mcp/cache)
CACHE_DIR=

# Notes directory (defaults to ./notes inside the project)
NOTES_DIR=
